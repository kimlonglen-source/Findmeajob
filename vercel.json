{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron-alerts?secret=${CRON_SECRET}",
      "schedule": "0 20 * * *"
    }
  ],
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/api/keywords",
      "dest": "/api/keywords.js"
    },
    {
      "src": "/api/jobs",
      "dest": "/api/jobs.js"
    },
    {
      "src": "/api/register",
      "dest": "/api/register.js"
    },
    {
      "src": "/api/login",
      "dest": "/api/register.js"
    },
    {
      "src": "/api/submit-job",
      "dest": "/api/employer-jobs.js"
    },
    {
      "src": "/api/admin",
      "dest": "/api/admin.js"
    },
    {
      "src": "/api/approved-jobs",
      "dest": "/api/approved-jobs.js"
    },
    {
      "src": "/api/employer-jobs",
      "dest": "/api/employer-jobs.js"
    },
    {
      "src": "/api/reset-password",
      "dest": "/api/reset-password.js"
    },
    {
      "src": "/api/track",
      "dest": "/api/approved-jobs.js"
    },
    {
      "src": "/api/apply",
      "dest": "/api/apply.js"
    },
    {
      "src": "/api/seeker",
      "dest": "/api/seeker.js"
    },
    {
      "src": "/api/seeker-apps",
      "dest": "/api/seeker-apps.js"
    },
    {
      "src": "/api/cron-alerts",
      "dest": "/api/cron-alerts.js"
    },
    {
      "src": "/admin.html",
      "dest": "/public/admin.html"
    },
    {
      "src": "/employer-portal.html",
      "dest": "/public/employer-portal.html"
    },
    {
      "src": "/logo-icon.svg",
      "dest": "/public/logo-icon.svg"
    },
    {
      "src": "/challenge",
      "status": 301,
      "headers": { "Location": "/practice-sim" }
    },
    {
      "src": "/practice-sim",
      "dest": "/public/practice-sim.html"
    },
    {
      "src": "/practice/([a-z]+)",
      "dest": "/public/practice-sim.html?s=$1"
    },
    {
      "src": "/decide",
      "dest": "/public/decide.html"
    },
    {
      "src": "/decode",
      "dest": "/public/decode.html"
    },
    {
      "src": "/pricing",
      "dest": "/public/pricing.html"
    },
    {
      "src": "/interview",
      "dest": "/public/interview.html"
    },
    {
      "src": "/negotiate",
      "dest": "/public/negotiate.html"
    },
    {
      "src": "/compare",
      "dest": "/public/compare.html"
    },
    {
      "src": "/score",
      "dest": "/public/score.html"
    },
    {
      "src": "/email",
      "dest": "/public/email.html"
    },
    {
      "src": "/write-cv",
      "status": 301,
      "headers": { "Location": "/match.html#apply" }
    },
    {
      "src": "/apply",
      "status": 301,
      "headers": { "Location": "/match.html#apply" }
    },
    {
      "src": "/cover-letter",
      "status": 301,
      "headers": { "Location": "/match.html#apply" }
    },
    {
      "src": "/terms",
      "dest": "/public/terms.html"
    },
    {
      "src": "/privacy",
      "dest": "/public/privacy.html"
    },
    {
      "src": "/salary",
      "dest": "/public/salary.html"
    },
    {
      "src": "/interview-sim",
      "dest": "/public/interview-sim.html"
    },
    {
      "src": "/trades",
      "dest": "/public/trades.html"
    },
    {
      "src": "/trades/builder",
      "dest": "/public/trades/builder.html"
    },
    {
      "src": "/trades/electrician",
      "dest": "/public/trades/electrician.html"
    },
    {
      "src": "/trades/plumber",
      "dest": "/public/trades/plumber.html"
    },
    {
      "src": "/trades/mechanic",
      "dest": "/public/trades/mechanic.html"
    },
    {
      "src": "/trades/apprentice",
      "dest": "/public/trades/apprentice.html"
    },
    {
      "src": "/healthcare",
      "dest": "/public/healthcare.html"
    },
    {
      "src": "/healthcare/rn",
      "dest": "/public/healthcare/rn.html"
    },
    {
      "src": "/healthcare/hca",
      "dest": "/public/healthcare/hca.html"
    },
    {
      "src": "/healthcare/midwife",
      "dest": "/public/healthcare/midwife.html"
    },
    {
      "src": "/healthcare/allied-health",
      "dest": "/public/healthcare/allied-health.html"
    },
    {
      "src": "/newcomers",
      "dest": "/public/newcomers.html"
    },
    {
      "src": "/graduates",
      "dest": "/public/graduates.html"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/api/approved-jobs.js?sitemap=1"
    },
    {
      "src": "/blog/rss",
      "dest": "/api/approved-jobs.js?blogRss=1"
    },
    {
      "src": "/blog/(.+)",
      "dest": "/api/approved-jobs.js?blogPost=$1"
    },
    {
      "src": "/blog/?",
      "dest": "/api/approved-jobs.js?blogPage=1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}